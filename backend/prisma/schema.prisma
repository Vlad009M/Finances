generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ROOT
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  password         String
  name             String
  avatarUrl        String?
  role             Role          @default(USER)
  blocked          Boolean       @default(false)
  emailVerified    Boolean       @default(false)
  verifyToken      String?
  verifyTokenExp   DateTime?
  createdAt        DateTime      @default(now())
  transactions     Transaction[]
  categories       Category[]
  sentMessages     Message[]     @relation("SentMessages")
  receivedMessages Message[]     @relation("ReceivedMessages")
  gameProfile      GameProfile?
  budgets Budget[]
  feedback  Feedback[]
}

model Category {
  id           String        @id @default(uuid())
  name         String
  icon         String?
  color        String?
  type         String
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  budgets Budget[]
}

model Transaction {
  id          String    @id @default(uuid())
  amount      Float
  type        String
  description String?
  date        DateTime  @default(now())
  userId      String
  categoryId  String
  user        User      @relation(fields: [userId], references: [id])
  category    Category  @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([date])
  @@index([userId, date])
}

model Message {
  id        String   @id @default(uuid())
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  fromId    String
  toId      String
  from      User     @relation("SentMessages", fields: [fromId], references: [id])
  to        User     @relation("ReceivedMessages", fields: [toId], references: [id])
}

model GameProfile {
  id            String        @id @default(uuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp            Int           @default(0)
  level         Int           @default(1)
  streak        Int           @default(0)
  lastActiveDate DateTime?
  totalSaved    Float         @default(0)
  archetype     String?
  achievements  Achievement[]
  challenges    WeeklyChallenge[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Achievement {
  id            String      @id @default(uuid())
  gameProfileId String
  gameProfile   GameProfile @relation(fields: [gameProfileId], references: [id], onDelete: Cascade)
  code          String      // унікальний код ачівки
  unlockedAt    DateTime    @default(now())

  @@unique([gameProfileId, code])
}

model WeeklyChallenge {
  id            String      @id @default(uuid())
  gameProfileId String
  gameProfile   GameProfile @relation(fields: [gameProfileId], references: [id], onDelete: Cascade)
  weekStart     DateTime
  type          String      // напр. "spend_less_food"
  targetAmount  Float?
  currentAmount Float       @default(0)
  completed     Boolean     @default(false)
  xpReward      Int         @default(100)

  @@unique([gameProfileId, weekStart])
}

model Budget {
  id         String   @id @default(uuid())
  userId     String
  categoryId String
  amount     Float
  month      Int
  year       Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@index([userId, month, year])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String   // 'bug' | 'idea' | 'other'
  text      String
  rating    Int?
  createdAt DateTime @default(now())
}